{
  "name": "signalk-frothfet-plugin",
  "version": "1.0.0",
  "description": "Open hardware multi-channel digital load controller.  Data in, control, and remote access.",
  "main": "src/index.js",
  "files": [
    "src/",
    "public/",
    "docs/screenshots/"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage test/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "eslint --fix . && prettier --write .",
    "format:check": "eslint . && prettier --check .",
    "prepare": "husky",
    "release": "git tag -d v$npm_package_version; git tag v$npm_package_version && git push && git push origin v$npm_package_version"
  },
  "lint-staged": {
    "*.{js,cjs}": "eslint --fix",
    "*.mjs": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,html,css}": "prettier --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoeken/signalk-frothfet-plugin.git"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-digital-switching"
  ],
  "signalk": {
    "displayName": "Frothfet",
    "appIcon": "logo.png",
    "screenshots": [
      "./docs/screenshots/chooser.png",
      "./docs/screenshots/frothfet.png"
    ]
  },
  "author": "Zach Hoeken",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/hoeken/signalk-frothfet-plugin/issues"
  },
  "homepage": "https://github.com/hoeken/signalk-frothfet-plugin#readme",
  "dependencies": {
    "http-proxy": "^1.18.1",
    "yarrboard-client": "^1.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.3",
    "ws": "^8.18.0"
  }
}
